---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
---

<Layout title="Tools · dark64">
  <h1 class="text-xl mb-1">&gt; ls ./tools</h1>
  <p class="text-neutral-500 text-sm mb-6">Found {tools.length} entries.</p>

  <div class="space-y-4">
    {tools.map((tool) => (
      <a
        href={`/tools/${tool.slug}`}
        class="block border border-neutral-700 hover:border-white p-4 transition-colors group"
      >
        <div class="flex gap-4 items-start">
          <div class="w-16 h-16 shrink-0 border border-neutral-700 bg-neutral-800 flex items-center justify-center overflow-hidden">
            <img
              src={tool.image}
              alt={tool.name}
              class="w-full h-full object-cover"
              onerror="this.style.display='none';this.parentElement.innerHTML='<span class=\'text-neutral-600 text-2xl\'>?</span>'"
            />
          </div>
          <div class="min-w-0">
            <h2 class="text-neutral-200 group-hover:text-white font-bold">
              {tool.name}
              <span class="text-neutral-500 font-normal text-sm ml-2">v{tool.version}</span>
            </h2>
            <p class="text-neutral-400 text-sm mt-1">{tool.description}</p>
            <p class="text-neutral-600 text-xs mt-2">[{tool.platform}]</p>
          </div>
        </div>
      </a>
    ))}
  </div>

  <p class="text-neutral-500 text-sm mt-8">EOF</p>
</Layout>
